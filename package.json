{
  "name": "fab",
  "homepage": "https://LaSarsoJackson.github.io/fab",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.8.2",
    "@emotion/styled": "^11.8.1",
    "@mui/icons-material": "^5.5.1",
    "@mui/material": "^5.5.3",
    "@mui/x-data-grid": "^5.7.0",
    "@testing-library/jest-dom": "^5.16.3",
    "@testing-library/react": "^12.1.4",
    "@turf/turf": "^7.2.0",
    "esri-leaflet": "^3.0.14",
    "esri-leaflet-vector": "^3.1.5",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "protomaps-leaflet": "^5.1.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-esri-leaflet": "^1.3.1",
    "react-leaflet": "^3.2.5",
    "react-scripts": "5.0.0",
    "react-spring-bottom-sheet": "^3.4.1",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "bash ./scripts/dev-start.sh",
    "start:web": "bun run sync:profile-shell && REACT_APP_ENVIRONMENT=development react-scripts --max_old_space_size=4096 start",
    "start:images": "python3 -m http.server 8000 --bind 127.0.0.1",
    "start:bun": "bun run start",
    "routing:offline:start": "bash ./scripts/routing/start-offline-valhalla.sh",
    "routing:offline:stop": "bash ./scripts/routing/stop-offline-valhalla.sh",
    "sync:profile-shell": "bun run scripts/sync-profile-shell.js",
    "deploy": "bash ./scripts/deploy-production.sh",
    "build:tour-data": "bun run scripts/generate-tour-biography-aliases.js",
    "build:geoparquet": "bash ./scripts/migrations/geoparquet/generate_geoparquet.sh",
    "build:pmtiles": "bash ./scripts/migrations/pmtiles/generate_pmtiles.sh",
    "build:site-twin": "bash ./scripts/geospatial/run_site_twin.sh",
    "build:site-twin:terrain": "bash ./scripts/geospatial/run_site_twin.sh --terrain-only",
    "build:site-twin:metadata": "bash ./scripts/geospatial/run_site_twin.sh --metadata-only",
    "build:data": "bun run build:tour-data && bun run scripts/precalculate-metadata.js",
    "describe:map-engine": "bun run scripts/geospatial/describe_map_engine.js",
    "validate:geoparquet": "bun run scripts/geospatial/validate_burial_source_parity.js",
    "build": "bash ./scripts/build-production.sh",
    "doctor": "bash ./scripts/dev-doctor.sh",
    "lint": "node_modules/.bin/eslint src test e2e --ext .js,.jsx",
    "check": "bash ./scripts/dev-doctor.sh && bun run lint && bash ./scripts/run-tests.sh",
    "test": "bash ./scripts/run-tests.sh",
    "test:bun": "rg --files src test -g '*.test.js' -0 | xargs -0 bun test",
    "test:dom": "node_modules/.bin/jest --config ./jest.dom.config.cjs --runInBand",
    "test:dom:watch": "node_modules/.bin/jest --config ./jest.dom.config.cjs --watch",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:watch": "bun test --watch src test",
    "test:coverage": "bun test --coverage src test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "test/**/*.js",
          "src/**/*.test.js",
          "src/**/*.test.jsx"
        ],
        "env": {
          "browser": true,
          "es2021": true,
          "node": true
        },
        "globals": {
          "globalThis": "readonly"
        }
      },
      {
        "files": [
          "src/BurialSidebar.test.jsx",
          "src/App.test.jsx"
        ],
        "rules": {
          "testing-library/no-node-access": "off"
        }
      },
      {
        "files": [
          "e2e/**/*.js"
        ],
        "env": {
          "browser": true,
          "es2021": true,
          "node": true
        },
        "rules": {
          "jest/valid-expect": "off",
          "testing-library/prefer-screen-queries": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@playwright/test": "^1.59.1",
    "babel-jest": "^29.7.0",
    "gh-pages": "^6.3.0",
    "http-proxy-middleware": "^3.0.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.5.1",
    "jest-environment-jsdom": "^27.5.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.8",
  "trustedDependencies": [
    "core-js",
    "core-js-pure"
  ]
}
